# ============================================================
# tweetfess — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# For Vercel: add these in Settings → Environment Variables.
# ============================================================

# --- REQUIRED (app won't start without these) ---

# Admin dashboard password. No default — must be set.
ADMIN_PASSWORD=your-secure-password-here

# Session cookie signing key. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# AES-256-GCM encryption key for sensitive settings in DB (passwords, TOTP secrets).
# Generate with: openssl rand -hex 32
# If not set, sensitive data is stored in plaintext (NOT recommended for production).
ENCRYPTION_KEY=

# --- REQUIRED for Twitter OAuth login ---

# X Developer Portal → App → Keys and tokens → OAuth 2.0 Client ID
OAUTH2_CLIENT_ID=

# X Developer Portal → App → Keys and tokens → OAuth 2.0 Client Secret
OAUTH2_CLIENT_SECRET=

# --- REQUIRED for Vercel deployment ---

# Production URL (used for OAuth callback). Must match the Callback URI in X Developer Portal.
# Example: https://tweetfess.vercel.app
# VERCEL_URL is auto-set by Vercel and used as fallback if NEXTAUTH_URL is not set.
NEXTAUTH_URL=

# --- DATABASE ---

# Prisma reads these exact names. For local dev, set them directly.
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Direct (unpooled) connection for Prisma migrations.
DATABASE_URL_UNPOOLED=

# On Vercel, Neon auto-provides POSTGRES_DATABASE_URL and POSTGRES_DATABASE_URL_UNPOOLED.
# You must map them in Vercel: DATABASE_URL = POSTGRES_DATABASE_URL
#                             DATABASE_URL_UNPOOLED = POSTGRES_DATABASE_URL_UNPOOLED

# --- CRON ---

# Secret token for /api/autopost cron endpoint. Required — the endpoint rejects
# requests without a matching Authorization: Bearer <CRON_SECRET> header.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- OPTIONAL ---

# Enable debug logging throughout the app. Set to "1" or "true" to enable.
# Comma-separated namespaces: DEBUG=submit,direct  (only those namespaces)
# DEBUG=

# Enable Prisma query duration logging. Set to "1" to enable.
# DEBUG_DB=1

# Alternative names for OAuth2 credentials (older naming convention)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# Alternative name for NEXTAUTH_SECRET
# SESSION_SECRET=

# Alternative name for NEXTAUTH_URL
# NEXT_PUBLIC_BASE_URL=

# X cookie string for direct posting (can also be set via Admin UI)
# X_COOKIE_STRING=
