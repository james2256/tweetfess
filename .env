# === DATABASE ===
# For Vercel: Use Vercel Postgres (Neon) connection string
# Get from: Vercel Dashboard → Storage → Postgres → .env.local tab
# Format: postgres://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menfess

# Direct URL for Prisma migrations (Vercel Postgres provides this separately)
# If using Vercel Postgres, copy the "direct url" from the dashboard
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/menfess

# === Twitter OAuth 2.0 (for user login) ===
# Get these from https://developer.twitter.com/en/portal/dashboard
# App type must be "Web App" with OAuth 2.0 enabled
# Callback URL: https://your-vercel-app.vercel.app/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# === X API v2 (for posting tweets - uses OAuth 1.0a) ===
# Get these from the same developer portal
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# === Admin password for dashboard access ===
ADMIN_PASSWORD=admin123

# === Session secret (for signing session cookies) ===
# IMPORTANT: Change this to a random 32+ character string in production!
SESSION_SECRET=change-this-to-a-random-string

# === Base URL (for OAuth callback) ===
# For local dev: http://localhost:3000
# For Vercel: https://your-vercel-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
