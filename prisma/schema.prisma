generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submitter {
  id                String       @id @default(cuid())
  twitterId         String       @unique  // X user ID from OAuth 2.0
  username          String       @unique
  displayName       String?
  profileImage      String?
  oauth2AccessToken String?      // OAuth 2.0 access token (for user identity)
  oauth2RefreshToken String?     // OAuth 2.0 refresh token
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  submissions       Submission[]
}

model Submission {
  id          String    @id @default(cuid())
  message     String
  status      String    @default("pending") // pending, approved, rejected, posted
  tweetId     String?   // X tweet ID after posting
  category    String?   // optional category/tag
  submitterId String
  submitter   Submitter @relation(fields: [submitterId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
